---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title = "Vedang Barhate — Software Engineer",
  description = "Vedang Barhate — software engineer focused on backend platforms, retrieval systems, and reliable distributed software.",
  image = "/portfolio.png",
  type = "website",
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://vedangbarhate.com';
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

// Indexing control:
// - Vercel preview/development should be noindex (VERCEL_ENV !== 'production')
// - Non-Vercel builds should index when built in production mode
const shouldIndex =
  typeof process !== 'undefined' && process.env?.VERCEL_ENV
    ? process.env.VERCEL_ENV === 'production'
    : import.meta.env.PROD;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Vedang Barhate" />
    <link rel="canonical" href={canonicalUrl} />

    {!shouldIndex && <meta name="robots" content="noindex,nofollow" />}
    {shouldIndex && <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Vedang Barhate portfolio preview" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/portfolio.png" />
    <link rel="apple-touch-icon" href="/portfolio.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#09090b" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fafafa" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Figtree:wght@300..900&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <link rel="alternate" type="application/rss+xml" title="Vedang's Blog" href={`${siteUrl}/rss.xml`} />

    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        const migrated = localStorage.getItem('theme_defaulted_v2');
        if (!migrated) {
          localStorage.setItem('theme_defaulted_v2', '1');
          localStorage.setItem('theme', 'dark');
        }
        const theme = localStorage.getItem('theme') || stored || 'dark';
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>

    <slot name="head" />
  </head>

  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
