---
interface Props {
  year: string;
  title: string;
  duration: string;
  details: string;
}

const { year, title, duration, details } = Astro.props;
---

<ol class="flex flex-col relative border-l border-stone-300 dark:border-stone-700">
  <li class="mb-10 ml-6">
    <div class="absolute w-3 h-3 bg-orange-500 rounded-full mt-1.5 -left-1.5 ring-4 ring-white dark:ring-[#191715]" />
    <div class="flex flex-wrap gap-3 items-center mb-2">
      <span class="inline-block px-2.5 py-1 text-xs font-medium text-orange-500 bg-orange-500/10 border border-orange-500/20 rounded-md">
        {year}
      </span>
      <h3 class="text-lg font-semibold text-stone-900 dark:text-white">
        {title}
      </h3>
      <span class="text-sm text-stone-500 dark:text-stone-500">
        {duration}
      </span>
    </div>
    <p class="text-stone-600 dark:text-stone-400 leading-relaxed">
      {details}
    </p>
  </li>
</ol>
