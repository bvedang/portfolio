---
import Title from "./Title.astro";
---

<div class="flex flex-col mb-10 mx-auto sm:w-9/12 max-w-6xl mt-20">
    <div class="flex justify-center items-center">
        <form
            action="https://getform.io/f/481a67ec-317c-4b76-adb0-9568f9bbbd64"
            method="POST"
            class="p-4 flex flex-col w-full"
        >
            <div class="flex items-center justify-center">
                <Title>Contact</Title>
            </div>

            <input
                type="text"
                name="name"
                placeholder="Name"
                required
                class="p-2 bg-transparent border-2 rounded-md focus:outline-none"
            />
            <input
                type="email"
                name="email"
                placeholder="Email Address"
                required
                class="my-2 p-2 bg-transparent border-2 rounded-md focus:outline-none"
            />
            <textarea
                name="message"
                rows="10"
                required
                class="p-2 mb-4 bg-transparent border-2 rounded-md focus:outline-none"
                placeholder="Your message..."></textarea>

            <button
                type="submit"
                class="text-center inline-block px-8 py-3 text-base font-medium rounded-md text-black border border-stone-400 transition-all duration-500
        hover:text-white hover:bg-stone-900 dark:text-stone-300 dark:bg-stone-600 dark:hover:bg-white dark:hover:text-black"
            >
                Contact ME!
            </button>
        </form>
    </div>
</div>
