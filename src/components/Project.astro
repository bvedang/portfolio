interface Project {
  title: string;
  description: string;
  githubUrl?: string;
  liveUrl?: string;
  image: string;
  imageAlt: string;
  techStack: { name: string; icon: keyof typeof icons }[];
}

const projects: Project[] = [
  {
    title: "Personal Expense Manager",
    description: "An online web application that tracks individual expenses. You can add expenses and view monthly spending by category. The application offers graphs based on the user's added expenses and offers analytical views based on the user's prior spending. Application shows how much the user has spent or saved in comparison to the average for the preceding month for each category.",
    githubUrl: "https://github.com/bvedang/expense-manager",
    liveUrl: "https://bvedang.github.io/expense-manager/",
    image: "/images/expenseManager.jpg",
    imageAlt: "Screenshot of Personal Expense Manager project",
    techStack: [
      { name: "React Js", icon: "react" },
      { name: "Flask", icon: "flask" },
      { name: "Material-UI", icon: "materialui" },
    ],
  },
  {
    title: "Time-series Forecasting with Microservice Architecture",
    description: "This is web application that uses MicroServices Architecture for timeseries forecasting. Application pulls Github repositories data(issues, forks, branches, commits, release) using the Github repo api on the main flask server. After retrieving data from Github api it is sent to three different servers hosting 3 different timeseries-forecasting models i.e LSTM FB prophet and Statsmodel. Forecast data is visualized in frontEnd with React using Re-Chart",
    githubUrl: "https://github.com/bvedang/React-Flask-Microservice",
    image: "/images/microService.jpg",
    imageAlt: "Screenshot of time-series forecasting microservice project",
    techStack: [
      { name: "LSTM", icon: "tensorflow" },
      { name: "React", icon: "react" },
      { name: "Flask", icon: "flask" },
    ],
  },
  {
    title: "Effect of Noise on Sentiment Analysis using SVM and BERT",
    description: "This project is more of an experiment than an application. Here, we tested the impact of noise in sentiment analysis on a Support Vector Machine (SVM) model and a Bidirectional Encoder from Transformer (BERT) representation framework. We created different sized sample noisy datasets from 'Disneyland Reviews' and 'Amazon Reviews' containing equal positive, negative, and neutral labels. We then analyzed and visualized the performance of the SVM and BERT classifiers for different sample sizes and the presence of noise in the data with baseline results.",
    image: "/images/nlp.png",
    imageAlt: "Screenshot of sentiment analysis noise experiment project",
    techStack: [
      { name: "BERT", icon: "tensorflow" },
      { name: "Pandas", icon: "pandas" },
      { name: "Numpy", icon: "numpy" },
    ],
  },
];
---

<div id="projects" class="max-w-[75rem] mx-auto my-20 p-6">
  <div class="flex items-end justify-center md:mt-32 sm:mt-20 mt-16">
    <Title>Projects</Title>
  </div>

  {projects.map((project, index) => (
    <div class="project grid grid-cols-1 md:grid-cols-10 rounded-lg overflow-hidden transition-all duration-500 shadow-[0_10px_30px_-15px_#1c1917] hover:-translate-y-[0.5%] hover:shadow-[0_20px_30px_-15px_#1c1917] mb-8 dark:bg-stone-900 hover:dark:bg-[#292524] text-black dark:text-stone-300">
      {/* Text box - order changes based on index for alternating layout */}
      <div class={`p-8 md:col-span-6 ${index % 2 === 1 ? 'md:order-2' : ''}`}>
        {project.githubUrl ? (
          <a
            class="hover:dark:text-stone-50 transition-all duration-500"
            href={project.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <h3 class="text-2xl md:text-4xl leading-tight mb-12 lg:mb-16">{project.title}</h3>
          </a>
        ) : (
          <h3 class="text-2xl md:text-4xl leading-tight mb-12 lg:mb-16">{project.title}</h3>
        )}

        <div class="text-lg leading-relaxed mb-12 lg:mb-16">
          <h4 class="text-sm uppercase tracking-widest font-light mb-3">Description</h4>
          <p class="text-base">{project.description}</p>
          {project.liveUrl && (
            <div class="mt-4 flex align-center justify-end">
              <a
                class="text-sm transition-all duration-500 hover:dark:border-b hover:border-b hover:dark:border-stone-300 hover:border-stone-700"
                href={project.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Live Demo
              </a>
            </div>
          )}
        </div>

        <h4 class="flex justify-end text-xs uppercase tracking-widest font-light mb-3">Tech Stack</h4>
        <ul class="flex flex-wrap gap-2.5 justify-end list-none">
          {project.techStack.map((tech) => (
            <li class="flex gap-2 items-center px-2 py-0.5 text-xs leading-none">
              <div class="flex flex-col justify-center items-center">
                <div class="border dark:border-stone-300 border-stone-700 rounded-full p-3">
                  <svg
                    style="height: 2.5rem; width: 2.5rem;"
                    role="img"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                    set:html={icons[tech.icon]}
                  />
                </div>
                <span class="mt-1">{tech.name}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>

      {/* Image box */}
      <div class={`flex items-center md:col-span-4 overflow-hidden ${index % 2 === 1 ? 'md:order-1' : ''}`}>
        <img
          class="object-cover h-full w-full scale-[1.2]"
          src={project.image}
          alt={project.imageAlt}
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  ))}
</div>

<style>
  @media (max-width: 47em) {
    .project {
      background-color: #1c19177b;
    }

    .project > div:last-child {
      z-index: -1;
      grid-row: 1;
      grid-column: 1;
      opacity: 0.1;
    }

    .project > div:first-child {
      grid-row: 1;
      grid-column: 1;
    }
  }
</style>
