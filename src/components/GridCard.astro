---
interface Props {
  title: string;
  description?: string;
  image?: string;
  tags?: string[];
  href: string;
  type: 'project' | 'blog';
  featured?: boolean;
  githubUrl?: string;
  liveUrl?: string;
}

const { title, description, image, tags = [], href, type, featured = false, githubUrl, liveUrl } = Astro.props;

const tagThemes: Record<string, { a: string; b: string; glyph: string }> = {
  linux: { a: "var(--accent-3)", b: "var(--accent-2)", glyph: "λ" },
  ebpf: { a: "var(--accent)", b: "var(--accent-3)", glyph: "⟟" },
  systems: { a: "var(--accent-2)", b: "var(--accent)", glyph: "⟐" },
  react: { a: "var(--accent-3)", b: "var(--accent)", glyph: "◎" },
  python: { a: "var(--accent)", b: "var(--accent-2)", glyph: "⌁" },
  default: { a: "var(--muted)", b: "var(--accent-3)", glyph: "⧉" },
};

const firstTag = tags[0]?.toLowerCase() || "default";
const theme = tagThemes[firstTag] || tagThemes.default;
---

<article
  class:list={[
    "panel panel-hover group overflow-hidden self-start relative",
    featured && "lg:col-span-2"
  ]}
  style={`--g1: ${theme.a}; --g2: ${theme.b};`}
>
  <div class="grid grid-rows-[auto_1fr]">
    <div class="relative aspect-[16/10] overflow-hidden">
      {image ? (
        <img
          src={image}
          alt={title}
          width={900}
          height={560}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
          loading={featured ? "eager" : "lazy"}
          decoding="async"
        />
      ) : (
        <div class="w-full h-full grid place-items-center card-gradient">
          <div class="headline text-5xl sm:text-6xl" style="opacity: 0.22; color: var(--accent-ink);">
            {theme.glyph}
          </div>
        </div>
      )}

      <div class="absolute inset-0 pointer-events-none media-glow"></div>
    </div>

    <div class="p-5 sm:p-6 relative z-20 pointer-events-none">
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <p class="text-xs uppercase tracking-[0.22em] muted">
            {type === "project" ? "Project" : "Writing"}
          </p>
          <h3 class="headline mt-2 text-lg sm:text-xl leading-tight ink">
            {title}
          </h3>
        </div>
        <span class="chip px-3 py-1 text-[11px]" style="font-family: var(--font-mono);">
          {tags[0] ? `#${tags[0]}` : "—"}
        </span>
      </div>

      {description && (
        <p class="mt-3 muted leading-relaxed line-clamp-2">
          {description}
        </p>
      )}

      {tags.length > 1 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {tags.slice(1, 4).map((tag) => (
            <span class="chip px-3 py-1 text-xs" style="font-family: var(--font-mono);">
              {tag}
            </span>
          ))}
        </div>
      )}

      {type === "project" && (githubUrl || liveUrl) && (
        <div class="mt-6 flex flex-wrap gap-2 relative z-30 pointer-events-auto">
          {liveUrl && (
            <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost text-sm">
              Live <span aria-hidden="true" style="font-family: var(--font-mono);">↗</span>
            </a>
          )}
          {githubUrl && (
            <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost text-sm">
              Source <span aria-hidden="true" style="font-family: var(--font-mono);">↗</span>
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <a
    href={href}
    class="absolute inset-0 z-10"
    aria-label={title}
  ></a>
</article>

<style>
  .card-gradient {
    background:
      radial-gradient(500px 220px at 18% 10%, color-mix(in oklab, var(--g1) 35%, transparent), transparent 65%),
      radial-gradient(420px 240px at 82% 74%, color-mix(in oklab, var(--g2) 30%, transparent), transparent 60%),
      linear-gradient(135deg, var(--g1), var(--g2));
  }

  .media-glow {
    background:
      radial-gradient(520px 220px at 18% 0%, color-mix(in oklab, var(--g1) 25%, transparent), transparent 65%),
      radial-gradient(520px 220px at 86% 100%, color-mix(in oklab, var(--g2) 18%, transparent), transparent 70%),
      linear-gradient(to top, color-mix(in oklab, var(--bg) 88%, transparent), transparent 70%);
    opacity: 0.75;
  }
  </style>
