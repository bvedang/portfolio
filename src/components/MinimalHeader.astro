---
const navLinks = [
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[var(--bg)] border-b border-[var(--border)]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <nav class="flex items-center justify-between h-14">
      <!-- Logo -->
      <a
        href="/"
        class="headline inline-flex items-center gap-3 text-base ink"
        aria-label="Home"
      >
        <span
          class="inline-flex h-8 w-8 items-center justify-center text-sm font-bold"
          style="background: var(--accent); color: var(--accent-ink); border-radius: var(--radius);"
        >
          VB
        </span>
        <span class="hidden sm:inline text-sm" style="color: var(--muted);">
          Vedang Barhate
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1 h-full">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "nav-link px-3 text-sm transition-colors h-full inline-flex items-center",
              isActive(link.href)
                ? "nav-link-active"
                : "nav-link-inactive"
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))}

        <!-- Theme toggle -->
        <button
          type="button"
          id="theme-toggle"
          class="ml-3 h-10 w-10 grid place-items-center border border-[var(--border)] transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
          style="border-radius: var(--radius);"
          aria-label="Toggle theme"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg
            id="sun-icon"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-4 h-4 hidden dark:block"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
            />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg
            id="moon-icon"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-4 h-4 block dark:hidden"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
            />
          </svg>
        </button>

        <!-- Contact link -->
        <a href="mailto:vedangbarhate@gmail.com" class="btn btn-primary ml-3 text-sm py-2 px-4">
          Let's talk
          <span aria-hidden="true" style="font-family: var(--font-mono);">&#8599;</span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        id="mobile-menu-btn"
        class="md:hidden h-10 w-10 grid place-items-center border border-[var(--border)]"
        style="border-radius: var(--radius);"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <!-- Hamburger icon -->
        <svg id="hamburger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- Close icon (hidden by default) -->
        <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 z-40 hidden opacity-0 transition-opacity duration-300"
  style="background: rgba(9, 9, 11, 0.6);"
  aria-hidden="true"
></div>

<!-- Mobile Menu Panel -->
<div
  id="mobile-menu-panel"
  class="fixed top-0 right-0 bottom-0 w-72 z-50 transform translate-x-full transition-transform duration-300 ease-out bg-[var(--bg)] border-l border-[var(--border)]"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
>
  <div class="flex flex-col h-full p-6 pt-20">
    <nav class="flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "mobile-nav-link text-lg py-3 px-3 transition-colors",
            isActive(link.href) ? "text-[var(--accent)] font-medium" : "ink"
          ]}
          style={`border-radius: var(--radius);`}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="mt-auto space-y-3">
      <!-- Theme toggle in mobile -->
      <button
        type="button"
        id="mobile-theme-toggle"
        class="flex items-center gap-3 w-full py-3 px-3 transition-colors border border-[var(--border)]"
        style="border-radius: var(--radius);"
      >
        <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
        <span class="text-sm dark:hidden ink">Dark Mode</span>
        <span class="text-sm hidden dark:inline ink">Light Mode</span>
      </button>

      <!-- Contact link -->
      <a
        href="mailto:vedangbarhate@gmail.com"
        class="mobile-nav-link btn btn-primary w-full justify-center"
      >
        Let's talk <span aria-hidden="true" style="font-family: var(--font-mono);">&#8599;</span>
      </a>
    </div>
  </div>
</div>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const mobileThemeToggle = document.getElementById('mobile-theme-toggle');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  const toggleTheme = () => {
    const isDark = document.documentElement.classList.contains('dark');

    if (isDark) {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
  };

  themeToggle?.addEventListener('click', toggleTheme);
  mobileThemeToggle?.addEventListener('click', toggleTheme);

  const openMobileMenu = () => {
    mobileMenuOverlay?.classList.remove('hidden');
    requestAnimationFrame(() => {
      mobileMenuOverlay?.classList.remove('opacity-0');
      mobileMenuPanel?.classList.remove('translate-x-full');
    });
    hamburgerIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    mobileMenuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeMobileMenu = () => {
    mobileMenuOverlay?.classList.add('opacity-0');
    mobileMenuPanel?.classList.add('translate-x-full');
    hamburgerIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';

    setTimeout(() => {
      mobileMenuOverlay?.classList.add('hidden');
    }, 300);
  };

  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  });

  mobileMenuOverlay?.addEventListener('click', closeMobileMenu);

  mobileNavLinks.forEach(link => {
    link.addEventListener('click', closeMobileMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeMobileMenu();
    }
  });
</script>

<style>
  .nav-link {
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }

  .nav-link-inactive {
    color: var(--muted);
  }

  .nav-link-inactive:hover {
    color: var(--accent);
  }

  .nav-link-active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>
