---
const navLinks = [
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="fixed top-0 left-0 right-0 z-50">
  <div class="max-w-6xl mx-auto px-4 pt-4">
    <nav class="panel px-4 py-3 sm:px-5 sm:py-3.5 flex items-center justify-between">
      <!-- Logo / Name -->
      <a
        href="/"
        class="headline inline-flex items-center gap-2 text-base sm:text-lg ink"
        aria-label="Home"
      >
        <span
          class="inline-flex h-9 w-9 items-center justify-center rounded-full"
          style="background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: var(--accent-ink); box-shadow: 0 12px 28px color-mix(in oklab, var(--accent) 22%, transparent);"
        >
          VB
        </span>
        <span class="hidden sm:inline muted text-sm" style="font-family: var(--font-mono); letter-spacing: 0.04em;">
          / portfolio
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-2">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "nav-link px-3 py-2 text-sm rounded-full transition-colors",
              isActive(link.href)
                ? "nav-link-active"
                : "nav-link-inactive"
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))}

        <!-- Theme toggle -->
        <button
          type="button"
          id="theme-toggle"
          class="ml-2 h-10 w-10 grid place-items-center rounded-full border"
          style="border-color: color-mix(in oklab, var(--border) 78%, transparent); background: color-mix(in oklab, var(--surface-2) 58%, transparent);"
          aria-label="Toggle theme"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg
            id="sun-icon"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-5 h-5 hidden dark:block"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
            />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg
            id="moon-icon"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-5 h-5 block dark:hidden"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
            />
          </svg>
        </button>

        <!-- Contact link -->
        <a href="mailto:vedangbarhate@gmail.com" class="btn btn-primary ml-2">
          <span class="hidden lg:inline">Let’s talk</span>
          <span class="lg:hidden">Contact</span>
          <span aria-hidden="true" style="font-family: var(--font-mono); opacity: 0.9;">↗</span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        id="mobile-menu-btn"
        class="md:hidden h-10 w-10 grid place-items-center rounded-full border"
        style="border-color: color-mix(in oklab, var(--border) 78%, transparent); background: color-mix(in oklab, var(--surface-2) 58%, transparent);"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <!-- Hamburger icon -->
        <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- Close icon (hidden by default) -->
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 z-40 hidden opacity-0 transition-opacity duration-300"
  style="background: color-mix(in oklab, var(--ink) 35%, transparent);"
  aria-hidden="true"
></div>

<!-- Mobile Menu Panel -->
<div
  id="mobile-menu-panel"
  class="fixed top-0 right-0 bottom-0 w-80 z-50 transform translate-x-full transition-transform duration-300 ease-out"
  style="background: color-mix(in oklab, var(--surface) 94%, transparent); border-left: 1px solid color-mix(in oklab, var(--border) 70%, transparent); backdrop-filter: blur(12px);"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
>
  <div class="flex flex-col h-full p-6 pt-20">
    <nav class="flex flex-col gap-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "mobile-nav-link text-lg py-2 transition-colors rounded-xl px-3",
            isActive(link.href) ? "mobile-link-active" : "ink"
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="mt-auto space-y-4">
      <!-- Theme toggle in mobile -->
      <button
        type="button"
        id="mobile-theme-toggle"
        class="flex items-center gap-3 w-full py-3 px-3 rounded-xl transition-colors"
        style="border: 1px solid color-mix(in oklab, var(--border) 78%, transparent); background: color-mix(in oklab, var(--surface-2) 55%, transparent);"
      >
        <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
        <span class="dark:hidden ink">Dark Mode</span>
        <span class="hidden dark:inline ink">Light Mode</span>
      </button>

      <!-- Contact link -->
      <a
        href="mailto:vedangbarhate@gmail.com"
        class="mobile-nav-link btn btn-primary w-full justify-center"
      >
        Let’s talk <span aria-hidden="true" style="font-family: var(--font-mono);">↗</span>
      </a>
    </div>
  </div>
</div>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const mobileThemeToggle = document.getElementById('mobile-theme-toggle');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  const toggleTheme = () => {
    const isDark = document.documentElement.classList.contains('dark');

    if (isDark) {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
  };

  themeToggle?.addEventListener('click', toggleTheme);
  mobileThemeToggle?.addEventListener('click', toggleTheme);

  const openMobileMenu = () => {
    mobileMenuOverlay?.classList.remove('hidden');
    requestAnimationFrame(() => {
      mobileMenuOverlay?.classList.remove('opacity-0');
      mobileMenuPanel?.classList.remove('translate-x-full');
    });
    hamburgerIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    mobileMenuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeMobileMenu = () => {
    mobileMenuOverlay?.classList.add('opacity-0');
    mobileMenuPanel?.classList.add('translate-x-full');
    hamburgerIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';

    setTimeout(() => {
      mobileMenuOverlay?.classList.add('hidden');
    }, 300);
  };

  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  });

  mobileMenuOverlay?.addEventListener('click', closeMobileMenu);

  mobileNavLinks.forEach(link => {
    link.addEventListener('click', closeMobileMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeMobileMenu();
    }
  });
</script>

<style>
  .nav-link-inactive {
    color: var(--muted);
  }

  .nav-link-inactive:hover {
    color: var(--ink);
  }

  .nav-link-active {
    background: color-mix(in oklab, var(--accent) 24%, transparent);
    color: var(--ink);
    border: 1px solid color-mix(in oklab, var(--accent) 40%, var(--border));
  }

  .mobile-link-active {
    background: linear-gradient(135deg, color-mix(in oklab, var(--accent) 28%, transparent), color-mix(in oklab, var(--accent-3) 16%, transparent));
    border: 1px solid color-mix(in oklab, var(--accent) 42%, var(--border));
  }
</style>
