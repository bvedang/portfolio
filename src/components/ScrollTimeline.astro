---
interface TimelineEntry {
    title: string;          // Date range (e.g., "Dec 2025 - Present")
    subtitle: string;       // Role title
    organization: string;   // Company name
    duration?: string;      // Duration label
    content: string;        // Description
    technologies?: string[]; // Tech tags
    isCurrent?: boolean;    // Show current badge
}

interface Props {
    data: TimelineEntry[];
    id?: string;
}

const { data, id = `timeline-${Math.random().toString(36).slice(2, 9)}` } =
    Astro.props;
---

<div class="timeline-container relative" id={id}>
    {/* Timeline line */}
    <div
        class="timeline-line absolute left-[7px] top-0 bottom-0 w-px"
        style="background: linear-gradient(to bottom, transparent, color-mix(in oklab, var(--border) 90%, transparent), transparent);"
        style="mask-image: linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);"
    >
        <div
            class="timeline-beam absolute inset-x-0 top-0 w-px rounded-full opacity-0 transition-opacity duration-300"
            style="background: linear-gradient(to top, var(--accent), color-mix(in oklab, var(--accent-2) 55%, transparent), transparent);"
            style="height: 0%;"
        >
        </div>
    </div>

    {/* Timeline entries */}
    <div class="space-y-6">
        {
            data.map((item, index) => (
                <div
                    class="timeline-entry relative pl-8"
                    style={`animation: fadeSlideIn 0.4s ease-out ${index * 80}ms both`}
                >
                    {/* Timeline dot */}
                    <div class="absolute left-0 top-6 w-[15px] h-[15px] rounded-full flex items-center justify-center" style="background: var(--bg);">
                        <div
                          class="w-[9px] h-[9px] rounded-full"
                          style={item.isCurrent
                            ? "background: var(--accent); box-shadow: 0 0 0 5px color-mix(in oklab, var(--accent) 20%, transparent);"
                            : "background: color-mix(in oklab, var(--muted) 55%, var(--border));"
                          }
                        />
                    </div>

                    {/* Card */}
                    <div class="timeline-card panel panel-hover group p-5 sm:p-6">
                        {/* Header: Title and Current badge */}
                        <div class="flex items-start justify-between gap-3 mb-3">
                            <div class="min-w-0">
                                <h4 class="headline text-base sm:text-lg ink mb-0.5 transition-colors" style="line-height: 1.1;">
                                    {item.subtitle}
                                </h4>
                                <p class="text-sm muted">
                                    {item.organization}
                                </p>
                            </div>
                            {item.isCurrent && (
                                <span class="shrink-0 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium" style="background: color-mix(in oklab, var(--accent) 18%, transparent); border: 1px solid color-mix(in oklab, var(--accent) 32%, transparent); color: var(--ink);">
                                    <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background: var(--accent);" />
                                    Current
                                </span>
                            )}
                        </div>

                        {/* Date and duration */}
                        <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs sm:text-sm muted mb-3" style="font-family: var(--font-mono);">
                            <span>{item.title}</span>
                            {item.duration && (
                                <>
                                    <span style="opacity: 0.6;">·</span>
                                    <span>{item.duration}</span>
                                </>
                            )}
                        </div>

                        {/* Description */}
                        <p class="muted text-sm leading-relaxed">
                            {item.content}
                        </p>

                        {/* Tech tags */}
                        {item.technologies && item.technologies.length > 0 && (
                            <div class="flex flex-wrap gap-1.5 sm:gap-2 mt-4 pt-4 border-t" style="border-color: color-mix(in oklab, var(--border) 70%, transparent);">
                                {item.technologies.map((tech) => (
                                    <span class="chip px-2 sm:px-2.5 py-0.5 sm:py-1 text-xs font-medium" style="font-family: var(--font-mono);">
                                        {tech}
                                    </span>
                                ))}
                            </div>
                        )}
                    </div>
                </div>
            ))
        }
    </div>
</div>

<style>
    @keyframes fadeSlideIn {
        from {
            opacity: 0;
            transform: translateY(12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (hover: none) {
        .timeline-card:hover {
            border-color: inherit;
            box-shadow: none;
        }
    }
</style>

<script>
    function initTimelineScroll() {
        const containers = document.querySelectorAll(".timeline-container");

        const prefersReducedMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
        ).matches;
        if (prefersReducedMotion) return;

        containers.forEach((container) => {
            const beam = container.querySelector(
                ".timeline-beam",
            ) as HTMLElement;
            if (!beam) return;

            beam.style.opacity = "1";

            const updateBeam = () => {
                const rect = container.getBoundingClientRect();
                const containerTop = rect.top;
                const containerHeight = rect.height;
                const windowHeight = window.innerHeight;

                const startOffset = windowHeight * 0.1;
                const endOffset = windowHeight * 0.5;

                const scrollStart = -containerTop + startOffset;
                const scrollRange = containerHeight - endOffset;

                let progress = scrollStart / scrollRange;
                progress = Math.max(0, Math.min(1, progress));

                const beamHeight = progress * containerHeight;
                beam.style.height = `${beamHeight}px`;
            };

            window.addEventListener("scroll", updateBeam, { passive: true });
            window.addEventListener("resize", updateBeam, { passive: true });
            updateBeam();
        });
    }

    document.addEventListener("DOMContentLoaded", initTimelineScroll);
    document.addEventListener("astro:page-load", initTimelineScroll);
</script>
