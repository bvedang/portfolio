---

<article id="skills" class="max-w-6xl mx-auto p-6 md:min-h-screen my-20 gap-1">
  <div class="flex items-end justify-center md:mt-32 sm:mt-20 mt-16">
    <Title>Skills</Title>
  </div>

  <!-- Frontend Skills -->
  <div class="grid md:grid-cols-10 grid-cols-1 mb-5">
    <div class="col-span-7 border dark:border-stone-300 border-stone-700 border-b-8 rounded-full"></div>
  </div>
  <div class="grid grid-cols-2 mb-16">
    <h3 class="text-lg">FrontEnd</h3>
    <div class="grid md:grid-cols-5 sm:grid-cols-3 grid-cols-2 gap-3">
      {frontendSkills.map((skill) => (
        <div class="flex flex-col justify-center items-center">
          <div class="border dark:border-stone-300 border-stone-700 rounded-full p-3">
            <svg
              style="height: 2.5rem; width: 2.5rem;"
              role="img"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
              set:html={skill.svg}
            />
          </div>
          <span class="text-center mt-1">{skill.name}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Backend Skills -->
  <div class="grid grid-cols-2">
    <h3 class="text-lg">BackEnd</h3>
    <div class="grid md:grid-cols-5 sm:grid-cols-3 grid-cols-2 gap-3">
      {backendSkills.map((skill) => (
        <div class="flex flex-col justify-center items-center">
          <div class="border dark:border-stone-300 border-stone-700 rounded-full p-3">
            <svg
              style="height: 2.5rem; width: 2.5rem;"
              role="img"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
              set:html={skill.svg}
            />
          </div>
          <span class="text-center mt-1">{skill.name}</span>
        </div>
      ))}
    </div>
  </div>
</article>
