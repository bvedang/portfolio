---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MinimalHeader from "../../components/MinimalHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const projects = (await getCollection("projects", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Projects | Vedang Barhate"
  description="Software engineering projects spanning full-stack development, machine learning, and systems programming."
>
  <MinimalHeader />

  <main class="pt-28">
    <section class="px-6 py-12">
      <div class="max-w-6xl mx-auto">
        <p class="kicker">Projects</p>
        <h1 class="headline ink text-4xl sm:text-5xl lg:text-6xl mt-4">Things I built.</h1>
        <p class="muted leading-relaxed mt-5 text-lg max-w-2xl">
          A small collection of work spanning full‑stack apps, data projects, and systems‑adjacent experiments.
        </p>
      </div>
    </section>

    <section class="px-6 pb-14">
      <div class="max-w-6xl mx-auto">
        {projects.length === 0 ? (
          <div class="panel p-10 text-center">
            <p class="muted text-lg">No projects yet. Check back soon!</p>
          </div>
        ) : (
          <ul class="simple-list">
            {projects.map((project) => (
              <li>
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-3">
                  <a class="headline ink text-xl" href={`/projects/${project.slug}`}>
                    {project.data.title}
                  </a>

                  <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm" style="font-family: var(--font-mono);">
                    <a class="link-accent" style="border-bottom: 0;" href={`/projects/${project.slug}`}>Case study</a>
                    {project.data.liveUrl && (
                      <a class="link-accent" style="border-bottom: 0;" href={project.data.liveUrl} target="_blank" rel="noopener noreferrer">
                        Live ↗
                      </a>
                    )}
                    {project.data.githubUrl && (
                      <a class="link-accent" style="border-bottom: 0;" href={project.data.githubUrl} target="_blank" rel="noopener noreferrer">
                        Source ↗
                      </a>
                    )}
                  </div>
                </div>

                <p class="muted mt-2 leading-relaxed">{project.data.description}</p>

                {project.data.stack?.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {project.data.stack.slice(0, 6).map((t) => (
                      <span class="chip px-3 py-1 text-xs" style="font-family: var(--font-mono);">
                        {t}
                      </span>
                    ))}
                  </div>
                )}
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
