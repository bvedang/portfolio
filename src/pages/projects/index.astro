---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MinimalHeader from '../../components/MinimalHeader.astro';
import GridCard from '../../components/GridCard.astro';

// Get all non-draft projects sorted by order
const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Projects | Vedang Barhate"
  description="Software engineering projects showcasing full-stack development, machine learning, and systems programming."
>
  <MinimalHeader />

  <main class="max-w-6xl mx-auto px-4 py-12 pt-24">
    {/* Header */}
    <header class="mb-12">
      <a href="/" class="inline-flex items-center text-stone-500 dark:text-stone-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors mb-6">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Home
      </a>

      <h1 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-white mb-4">Projects</h1>
      <p class="text-stone-600 dark:text-stone-400 text-lg max-w-2xl">
        A collection of software engineering projects spanning full-stack development, machine learning, and data analysis.
      </p>
    </header>

    {/* Projects Grid */}
    {projects.length === 0 ? (
      <div class="text-center py-12">
        <p class="text-stone-600 dark:text-stone-400 text-lg">No projects yet. Check back soon!</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <GridCard
            title={project.data.title}
            description={project.data.description}
            image={project.data.image}
            tags={project.data.stack.slice(0, 3)}
            href={`/projects/${project.slug}`}
            type="project"
            featured={project.data.featured}
            githubUrl={project.data.githubUrl}
            liveUrl={project.data.liveUrl}
          />
        ))}
      </div>
    )}
  </main>

  {/* Footer */}
  <footer class="py-12 px-4 border-t border-stone-200 dark:border-stone-800">
    <div class="max-w-6xl mx-auto text-center text-sm text-stone-500">
      <p>Built by Vedang Barhate</p>
    </div>
  </footer>
</BaseLayout>
