---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MinimalHeader from "../../components/MinimalHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const projects = (await getCollection("projects", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Projects | Vedang Barhate"
  description="Software engineering projects spanning full-stack development, machine learning, and systems programming."
>
  <MinimalHeader />

  <main class="pt-20">
    <section class="px-6 py-10 sm:py-14">
      <div class="max-w-6xl mx-auto">
        <p class="kicker">Projects</p>
        <h1 class="headline ink text-4xl sm:text-5xl lg:text-6xl mt-4">
          Things I built<span style="color: var(--accent);">.</span>
        </h1>
        <p class="muted leading-relaxed mt-6 text-lg max-w-2xl">
          A small collection of work spanning full-stack apps, data projects, and systems-adjacent experiments.
        </p>
      </div>
    </section>

    <section class="px-6 pb-16 sm:pb-20">
      <div class="max-w-6xl mx-auto">
        <hr class="rule mb-8" />
        {projects.length === 0 ? (
          <div class="py-10 text-center">
            <p class="muted text-lg">No projects yet. Check back soon!</p>
          </div>
        ) : (
          <ul class="simple-list">
            {projects.map((project) => (
              <li>
                <a class="headline ink text-xl hover:text-[var(--accent)] transition-colors" href={`/projects/${project.slug}`}>
                  {project.data.title}
                </a>

                <p class="muted mt-2 leading-relaxed text-sm">{project.data.description}</p>

                {project.data.stack?.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {project.data.stack.slice(0, 6).map((t) => (
                      <span class="chip px-2.5 py-1 text-xs">
                        {t}
                      </span>
                    ))}
                  </div>
                )}

                <div class="mt-3 flex flex-wrap gap-x-4 gap-y-2 text-xs" style="font-family: var(--font-mono);">
                  <a class="link-accent" href={`/projects/${project.slug}`}>Case study</a>
                  {project.data.liveUrl && (
                    <a class="link-accent" href={project.data.liveUrl} target="_blank" rel="noopener noreferrer">
                      Live &#8599;
                    </a>
                  )}
                  {project.data.githubUrl && (
                    <a class="link-accent" href={project.data.githubUrl} target="_blank" rel="noopener noreferrer">
                      Source &#8599;
                    </a>
                  )}
                </div>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
