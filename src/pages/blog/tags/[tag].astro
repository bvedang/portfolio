---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import MinimalHeader from "../../../components/MinimalHeader.astro";
import SiteFooter from "../../../components/SiteFooter.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`Posts tagged "${tag}" | Vedang Barhate`} description={`Blog posts about ${tag}`}>
  <MinimalHeader />

  <main class="pt-28">
    <section class="px-6 py-12">
      <div class="max-w-6xl mx-auto">
        <p class="kicker">Tag</p>
        <h1 class="headline ink text-3xl sm:text-4xl lg:text-5xl mt-4">
          #{tag}
        </h1>
        <p class="muted mt-4" style="font-family: var(--font-mono);">
          {posts.length} post{posts.length !== 1 ? "s" : ""}
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="btn btn-ghost" href="/blog">All posts</a>
          <a class="btn btn-ghost" href="/rss.xml">RSS</a>
        </div>
      </div>
    </section>

    <section class="px-6 pb-14">
      <div class="max-w-6xl mx-auto">
        <ul class="simple-list">
          {posts.map((post) => (
            <li>
              <a class="headline ink text-xl" href={`/blog/${post.slug}`}>
                {post.data.title}
              </a>
              <p class="muted mt-2 leading-relaxed">{post.data.description}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {post.data.tags.map((t) => (
                  <span
                    class="chip px-3 py-1 text-xs"
                    style={`font-family: var(--font-mono); ${t === tag ? "background: color-mix(in oklab, var(--accent) 18%, transparent); border-color: color-mix(in oklab, var(--accent) 32%, var(--border)); color: var(--ink);" : ""}`}
                  >
                    {t}
                  </span>
                ))}
              </div>
              <p class="muted mt-3 text-sm" style="font-family: var(--font-mono);">
                {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
