---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import MinimalHeader from '../components/MinimalHeader.astro';
import GridCard from '../components/GridCard.astro';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://vedangbarhate.com';

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects', ({ data }) => !data.draft && data.featured))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout>
  <head slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": `${siteUrl}/#website`,
          "url": siteUrl,
          "name": "Vedang Barhate Portfolio"
        },
        {
          "@type": "WebPage",
          "@id": `${siteUrl}/#webpage`,
          "url": siteUrl,
          "name": "Vedang Barhate — Full-Stack Software Engineer",
          "isPartOf": { "@id": `${siteUrl}/#website` },
          "mainEntity": { "@id": `${siteUrl}/#person` }
        },
        {
          "@type": "Person",
          "@id": `${siteUrl}/#person`,
          "name": "Vedang Barhate",
          "url": siteUrl,
          "image": `${siteUrl}/portfolio.png`,
          "jobTitle": "Full-Stack Software Engineer",
          "sameAs": [
            "https://github.com/bvedang",
            "https://www.linkedin.com/in/vedang-barhate17/",
            "https://www.instagram.com/vedang_barhate/"
          ]
        }
      ]
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>

  <MinimalHeader />

  <main class="pt-20">
    <!-- Hero / Intro Section -->
    <section class="px-6 py-20 max-w-5xl mx-auto">
      <div class="max-w-2xl">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-stone-900 dark:text-white mb-4 leading-tight">
          Vedang Barhate
        </h1>
        <p class="text-xl md:text-2xl text-stone-600 dark:text-stone-400 font-serif italic mb-2" style="font-family: 'Playfair Display', serif;">
          I build backend systems in Java and Go.
        </p>
        <p class="text-stone-600 dark:text-stone-400 text-lg leading-relaxed mb-4 max-w-xl">
          I write about eBPF and Linux internals.
        </p>
        <p class="text-sm text-stone-500 dark:text-stone-500 mb-8">
          Recent work: cut SLA breaches 60% by fixing slow endpoints at Epsilon.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/projects"
            class="px-6 py-3 bg-orange-500 text-white rounded-lg hover:bg-orange-400 transition-colors"
          >
            View Projects
          </a>
          {blogPosts[0] && (
            <a
              href={`/blog/${blogPosts[0].slug}`}
              class="px-6 py-3 border border-stone-300 dark:border-stone-700 text-stone-700 dark:text-stone-300 rounded-lg hover:bg-stone-100 dark:hover:bg-stone-800 hover:text-stone-900 dark:hover:text-white transition-colors"
            >
              Read Latest Post
            </a>
          )}
        </div>
      </div>
    </section>

    <!-- Showcase Grid -->
    <section class="px-6 pb-20">
      <div class="max-w-6xl mx-auto">
        <!-- Section label -->
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-sm uppercase tracking-widest text-stone-500">Featured Work</h2>
          <div class="flex gap-4">
            <a href="/projects" class="text-sm text-stone-500 dark:text-stone-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors">
              All projects &rarr;
            </a>
            <a href="/blog" class="text-sm text-stone-500 dark:text-stone-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors">
              All posts &rarr;
            </a>
          </div>
        </div>

        <div class="showcase-grid">
          {projects[0] && (
            <GridCard
              title={projects[0].data.title}
              description={projects[0].data.description}
              image={projects[0].data.image}
              tags={projects[0].data.stack.slice(0, 3)}
              href={`/projects/${projects[0].slug}`}
              type="project"
              featured={true}
              githubUrl={projects[0].data.githubUrl}
              liveUrl={projects[0].data.liveUrl}
            />
          )}

          {blogPosts[0] && (
            <GridCard
              title={blogPosts[0].data.title}
              description={blogPosts[0].data.description}
              tags={blogPosts[0].data.tags}
              href={`/blog/${blogPosts[0].slug}`}
              type="blog"
            />
          )}

          {projects[1] && (
            <GridCard
              title={projects[1].data.title}
              description={projects[1].data.description}
              image={projects[1].data.image}
              tags={projects[1].data.stack.slice(0, 3)}
              href={`/projects/${projects[1].slug}`}
              type="project"
              githubUrl={projects[1].data.githubUrl}
              liveUrl={projects[1].data.liveUrl}
            />
          )}

          {blogPosts.slice(1, 3).map((post) => (
            <GridCard
              title={post.data.title}
              description={post.data.description}
              tags={post.data.tags}
              href={`/blog/${post.slug}`}
              type="blog"
            />
          ))}

          {projects[2] && (
            <GridCard
              title={projects[2].data.title}
              description={projects[2].data.description}
              image={projects[2].data.image}
              tags={projects[2].data.stack.slice(0, 3)}
              href={`/projects/${projects[2].slug}`}
              type="project"
              githubUrl={projects[2].data.githubUrl}
              liveUrl={projects[2].data.liveUrl}
            />
          )}
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-stone-200 dark:border-stone-800 py-12 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
        <!-- Navigation -->
        <nav class="flex flex-wrap gap-6 text-sm">
          <a href="/" class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors">Home</a>
          <a href="/projects" class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors">Projects</a>
          <a href="/blog" class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors">Blog</a>
          <a href="/about" class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors">About</a>
        </nav>

        <!-- Social links -->
        <div class="flex items-center gap-4">
          <a
            href="https://github.com/bvedang"
            target="_blank"
            rel="noopener noreferrer"
            class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/vedang-barhate17/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/vedang_barhate/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.794.646-1.439 1.44-1.439.793-.001 1.44.645 1.44 1.439z"/>
            </svg>
          </a>
          <a
            href="mailto:vedangbarhate@gmail.com"
            class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors"
            aria-label="Email"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="mt-8 pt-8 border-t border-stone-200 dark:border-stone-800 text-center text-sm text-stone-500">
        <p>Built by Vedang Barhate</p>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .showcase-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .showcase-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .showcase-grid > :first-child {
      grid-column: span 2;
    }
  }
</style>
