---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import MinimalHeader from "../components/MinimalHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://vedangbarhate.com";

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection("projects", ({ data }) => !data.draft && data.featured))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout>
  <head slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": `${siteUrl}/#website`,
            url: siteUrl,
            name: "Vedang Barhate Portfolio",
          },
          {
            "@type": "WebPage",
            "@id": `${siteUrl}/#webpage`,
            url: siteUrl,
            name: "Vedang Barhate — Full-Stack Software Engineer",
            isPartOf: { "@id": `${siteUrl}/#website` },
            mainEntity: { "@id": `${siteUrl}/#person` },
          },
          {
            "@type": "Person",
            "@id": `${siteUrl}/#person`,
            name: "Vedang Barhate",
            url: siteUrl,
            image: `${siteUrl}/portfolio.png`,
            jobTitle: "Full-Stack Software Engineer",
            sameAs: [
              "https://github.com/bvedang",
              "https://www.linkedin.com/in/vedang-barhate17/",
              "https://www.instagram.com/vedang_barhate/",
            ],
          },
        ],
      })}
    />
  </head>

  <MinimalHeader />

  <main class="pt-28">
    <section class="px-6 py-14 sm:py-16">
      <div class="max-w-6xl mx-auto">
        <p class="kicker">Software engineer</p>
        <h1 class="headline ink text-5xl sm:text-6xl mt-4">Vedang Barhate</h1>
        <p class="muted leading-relaxed mt-5 text-lg max-w-2xl">
          I build backend systems in Java and Go. I write about eBPF, Linux internals, and shipping reliable software.
        </p>
        <p class="muted mt-4 max-w-2xl" style="font-family: var(--font-mono);">
          Currently: building dispute systems at scale.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn btn-primary" href="mailto:vedangbarhate@gmail.com">
            Email <span aria-hidden="true" style="font-family: var(--font-mono);">↗</span>
          </a>
          <a class="btn btn-ghost" href="/projects">Projects</a>
          <a class="btn btn-ghost" href="/blog">Writing</a>
          <a class="btn btn-ghost" href="/about">About</a>
        </div>
      </div>
    </section>

    <section class="px-6 pb-14">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-10">
          <section>
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="headline ink text-xl sm:text-2xl">Projects</h2>
              <a class="link-accent text-sm" href="/projects" style="border-bottom: 0;">All</a>
            </div>

            <ul class="simple-list">
              {projects.length === 0 ? (
                <li>
                  <p class="muted">No featured projects yet.</p>
                  <a class="link-accent text-sm" style="border-bottom: 0;" href="/projects">Browse all projects</a>
                </li>
              ) : (
                projects.slice(0, 3).map((p) => (
                  <li>
                    <a class="headline ink text-lg" href={`/projects/${p.slug}`}>{p.data.title}</a>
                    <p class="muted mt-2 leading-relaxed">{p.data.description}</p>
                    <div class="mt-3 flex flex-wrap gap-2">
                      {p.data.stack.slice(0, 4).map((t) => (
                        <span class="chip px-3 py-1 text-xs" style="font-family: var(--font-mono);">{t}</span>
                      ))}
                    </div>
                  </li>
                ))
              )}
            </ul>
          </section>

          <section>
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="headline ink text-xl sm:text-2xl">Writing</h2>
              <a class="link-accent text-sm" href="/blog" style="border-bottom: 0;">All</a>
            </div>

            <ul class="simple-list">
              {blogPosts.length === 0 ? (
                <li>
                  <p class="muted">No posts yet.</p>
                  <a class="link-accent text-sm" style="border-bottom: 0;" href="/blog">Browse writing</a>
                </li>
              ) : (
                blogPosts.map((post) => (
                  <li>
                    <a class="headline ink text-lg" href={`/blog/${post.slug}`}>{post.data.title}</a>
                    <p class="muted mt-2 leading-relaxed">{post.data.description}</p>
                    <p class="muted mt-3 text-sm" style="font-family: var(--font-mono);">
                      {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
                    </p>
                  </li>
                ))
              )}
            </ul>
          </section>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
