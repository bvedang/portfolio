---
import BaseLayout from "../layouts/BaseLayout.astro";
import MinimalHeader from "../components/MinimalHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const workExperience = [
  {
    title: "Dec 2025 - Present",
    subtitle: "SDE II",
    organization: "Adyen",
    duration: "Ongoing",
    content:
      "Working on Visa RTSI Disputes platform. Building reliable payment dispute resolution systems at scale.",
    technologies: ["Java", "Kotlin", "PostgreSQL", "Kafka"],
    isCurrent: true,
  },
  {
    title: "Sept 2025 - Dec 2025",
    subtitle: "Senior Software Engineer",
    organization: "Protocoding",
    duration: "4 Months",
    content:
      "Built Aivre mobile app. Led development of mobile features and backend integrations.",
    technologies: ["React Native", "TypeScript", "Node.js"],
  },
  {
    title: "June 2024 - Sept 2025",
    subtitle: "Software Development Engineer",
    organization: "FIS",
    duration: "1 Year 4 Months",
    content:
      "Built Case-whisperer and Finance Case-Manager platforms. Developed financial case management systems processing high-volume transactions.",
    technologies: ["Java", "Spring Boot", "PostgreSQL", "AWS"],
  },
  {
    title: "Feb 2023 - May 2024",
    subtitle: "Software Engineer",
    organization: "Opstra Tech",
    duration: "1 Year 4 Months",
    content:
      "Built document search platform. Implemented search infrastructure and document processing pipelines.",
    technologies: ["Python", "Elasticsearch", "React"],
  },
  {
    title: "June 2019 - Dec 2020",
    subtitle: "Software Engineer",
    organization: "Shaili Pharma Chem",
    duration: "1 Year 7 Months",
    content:
      "Built inventory management system. React frontend, Flask backend. First production system I shipped.",
    technologies: ["React", "Flask", "PostgreSQL"],
  },
];

const education = [
  {
    title: "2021 - Dec 2022",
    subtitle: "MS Computer Science",
    organization: "Illinois Institute of Technology",
    content: "Focused on machine learning and databases. GPA: 3.7",
  },
  {
    title: "2015 - May 2019",
    subtitle: "BS Computer Science",
    organization: "Parul University",
    content:
      "The fundamentals: algorithms, data structures, compilers, how computers actually work.",
  },
];
---

<BaseLayout
  title="About | Vedang Barhate"
  description="Full-Stack Software Engineer with expertise in Java, Python, and modern web technologies."
>
  <MinimalHeader />

  <main class="pt-28">
    <section class="px-6 py-12">
      <div class="max-w-6xl mx-auto">
        <p class="kicker">About</p>
        <h1 class="headline ink text-4xl sm:text-5xl lg:text-6xl mt-4">Vedang.</h1>
        <p class="muted leading-relaxed mt-5 text-lg max-w-3xl">
          I’m a full‑stack software engineer with a systems bias. I care about latency, reliability, and clean APIs.
        </p>
        <p class="muted leading-relaxed mt-4 max-w-3xl">
          Lately I’m deep in eBPF and Linux internals. I write what I learn so it sticks.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn btn-primary" href="/VedangBarhate_resume.pdf" target="_blank" rel="noopener noreferrer">
            Resume <span aria-hidden="true" style="font-family: var(--font-mono);">↗</span>
          </a>
          <a class="btn btn-ghost" href="mailto:vedangbarhate@gmail.com">
            Email <span aria-hidden="true" style="font-family: var(--font-mono);">↗</span>
          </a>
          <a class="btn btn-ghost" href="https://github.com/bvedang" target="_blank" rel="noopener noreferrer">
            GitHub <span aria-hidden="true" style="font-family: var(--font-mono);">↗</span>
          </a>
          <a class="btn btn-ghost" href="https://www.linkedin.com/in/vedang-barhate17/" target="_blank" rel="noopener noreferrer">
            LinkedIn <span aria-hidden="true" style="font-family: var(--font-mono);">↗</span>
          </a>
        </div>
      </div>
    </section>

    <section class="px-6 pb-14">
      <div class="max-w-6xl mx-auto">
        <h2 class="headline ink text-2xl sm:text-3xl">Experience</h2>
        <ul class="simple-list">
          {workExperience.map((job) => (
            <li>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2">
                <p class="headline ink text-xl">
                  {job.subtitle} <span class="muted">· {job.organization}</span>
                </p>
                <p class="muted text-sm" style="font-family: var(--font-mono);">
                  {job.title}{job.duration ? ` · ${job.duration}` : ""}
                </p>
              </div>
              <p class="muted mt-2 leading-relaxed">{job.content}</p>
              {job.technologies?.length ? (
                <div class="mt-3 flex flex-wrap gap-2">
                  {job.technologies.map((t) => (
                    <span class="chip px-3 py-1 text-xs" style="font-family: var(--font-mono);">
                      {t}
                    </span>
                  ))}
                </div>
              ) : null}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="px-6 pb-14">
      <div class="max-w-6xl mx-auto">
        <h2 class="headline ink text-2xl sm:text-3xl">Education</h2>
        <ul class="simple-list">
          {education.map((school) => (
            <li>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2">
                <p class="headline ink text-xl">
                  {school.subtitle} <span class="muted">· {school.organization}</span>
                </p>
                <p class="muted text-sm" style="font-family: var(--font-mono);">
                  {school.title}
                </p>
              </div>
              <p class="muted mt-2 leading-relaxed">{school.content}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
