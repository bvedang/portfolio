---
import BaseLayout from "../layouts/BaseLayout.astro";
import MinimalHeader from "../components/MinimalHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const stack = [
  "Java",
  "Python",
  "TypeScript",
  "Go",
  "Spring Boot",
  "FastAPI",
  "Next.js",
  "PostgreSQL",
  "AWS",
  "Kafka",
  "Kubernetes",
  "Terraform",
];

const certifications = [
  "AWS Developer",
  "AWS Solutions Architect",
  "AWS Cloud Practitioner",
  "Deep Learning Specialization",
];

const workExperience = [
  {
    title: "Dec 2025 – Present",
    subtitle: "SDE II",
    organization: "Adyen",
    content:
      "I’m working on Visa RTSI disputes. The job is to untangle lifecycle state from older ledger assumptions and make testing work in real scheme sandboxes.",
    technologies: ["Java", "Jersey", "PostgreSQL", "RabbitMQ", "S3"],
    isCurrent: true,
  },
  {
    title: "Sept 2025 – Dec 2025",
    subtitle: "Senior Software Engineer",
    organization: "Protocoding",
    duration: "4 Months",
    content:
      "I worked on Aivre. I got sketch rendering up to 120 FPS and cleaned up auth so the app could get through App Store review.",
    technologies: ["React Native", "Go", "Next.js", "MongoDB", "AI SDK"],
  },
  {
    title: "June 2024 – Sept 2025",
    subtitle: "Software Development Engineer",
    organization: "FIS",
    duration: "1 Year 4 Months",
    content:
      "I built Case-whisperer and Finance Case-Manager. That meant LLM retrieval work on one side and case and transaction pipelines at 18M+ cases and 220M+ transactions a month on the other.",
    technologies: ["Next.js", "Spring Boot", "FastAPI", "PostgreSQL", "Kafka", "EKS", "Terraform"],
  },
  {
    title: "Feb 2023 – May 2024",
    subtitle: "Software Engineer",
    organization: "Opstra Tech",
    duration: "1 Year 4 Months",
    content:
      "I built the document search platform. It cut retrieval from 45 minutes to under 5 and held up better during 3x traffic spikes.",
    technologies: ["Python", "Elasticsearch", "SQS", "React"],
  },
  {
    title: "June 2019 – Dec 2020",
    subtitle: "Software Engineer",
    organization: "Shaili Pharma Chem",
    duration: "1 Year 7 Months",
    content:
      "I built an inventory system for the Purchase and Finance teams with role-based access control and real-time stock tracking.",
    technologies: ["React", "Spring Boot", "PostgreSQL", "Okta"],
  },
];

const education = [
  {
    title: "2021 – Dec 2022",
    subtitle: "MS Computer Science",
    organization: "Illinois Institute of Technology",
    content: "Master of Computer Science.",
  },
  {
    title: "2015 – May 2019",
    subtitle: "BS Computer Science",
    organization: "Parul University",
    content: "Bachelor of Technology in Computer Science.",
  },
];
---

<BaseLayout
  title="About | Vedang Barhate"
  description="Software engineer with experience in backend platforms, retrieval systems, and high-volume financial infrastructure."
>
  <MinimalHeader />

  <main class="pt-20">
    <section class="px-6 py-10 sm:py-14">
      <div class="max-w-6xl mx-auto">
        <p class="kicker">About</p>
        <p class="muted leading-relaxed mt-4 text-lg max-w-3xl">
          I’m a software engineer who likes systems work. I care about latency, reliability, and APIs that stay easy to work with. Lately I’ve been building financial workflows, search-heavy platforms, and AI tools for engineers.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a class="btn btn-primary" href="mailto:vedang.inbox@gmail.com">
            Email <span aria-hidden="true" style="font-family: var(--font-mono);">&#8599;</span>
          </a>
          <a class="btn btn-ghost" href="/Vedang_Barhate_Resume_2026.docx" target="_blank" rel="noopener noreferrer" download>
            Resume (.docx) <span aria-hidden="true" style="font-family: var(--font-mono);">&#8599;</span>
          </a>
          <a class="btn btn-ghost" href="https://github.com/bvedang" target="_blank" rel="noopener noreferrer">
            GitHub <span aria-hidden="true" style="font-family: var(--font-mono);">&#8599;</span>
          </a>
          <a class="btn btn-ghost" href="https://www.linkedin.com/in/barhate-vedang/" target="_blank" rel="noopener noreferrer">
            LinkedIn <span aria-hidden="true" style="font-family: var(--font-mono);">&#8599;</span>
          </a>
        </div>
      </div>
    </section>

    <section class="px-6 pb-16 sm:pb-20">
      <div class="max-w-6xl mx-auto">
        <hr class="rule mb-10" />
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">
          <section>
            <p class="kicker mb-6">Selected Stack</p>
            <div class="flex flex-wrap gap-2">
              {stack.map((item) => (
                <span class="chip px-2.5 py-1 text-xs">{item}</span>
              ))}
            </div>
          </section>

          <section>
            <p class="kicker mb-6">Certifications</p>
            <div class="flex flex-wrap gap-2">
              {certifications.map((item) => (
                <span class="chip px-2.5 py-1 text-xs">{item}</span>
              ))}
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="px-6 pb-16 sm:pb-20">
      <div class="max-w-6xl mx-auto">
        <hr class="rule mb-10" />
        <p class="kicker mb-6">Experience</p>
        <ul class="simple-list">
          {workExperience.map((job) => (
            <li>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2">
                <p class="headline ink text-lg">
                  {job.subtitle} <span class="muted text-base">&#183; {job.organization}</span>
                </p>
                <p class="text-xs" style="font-family: var(--font-mono); color: var(--muted);">
                  {job.title}{job.duration ? ` · ${job.duration}` : ""}
                </p>
              </div>
              <p class="muted mt-2 leading-relaxed text-sm">{job.content}</p>
              {job.technologies?.length ? (
                <div class="mt-3 flex flex-wrap gap-2">
                  {job.technologies.map((t) => (
                    <span class="chip px-2.5 py-1 text-xs">
                      {t}
                    </span>
                  ))}
                </div>
              ) : null}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="px-6 pb-16 sm:pb-20">
      <div class="max-w-6xl mx-auto">
        <hr class="rule mb-10" />
        <p class="kicker mb-6">Education</p>
        <ul class="simple-list">
          {education.map((school) => (
            <li>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2">
                <p class="headline ink text-lg">
                  {school.subtitle} <span class="muted text-base">&#183; {school.organization}</span>
                </p>
                <p class="text-xs" style="font-family: var(--font-mono); color: var(--muted);">
                  {school.title}
                </p>
              </div>
              <p class="muted mt-2 leading-relaxed text-sm">{school.content}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
